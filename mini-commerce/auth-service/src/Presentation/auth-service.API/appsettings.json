{
    "Logging":  {
                    "LogLevel":  {
                                     "Default":  "Information",
                                     "Microsoft.AspNetCore":  "Warning"
                                 }
                },
    "AllowedHosts":  "*",
    "RabbitMQ":  "amqp://localhost",
    "ConnectionStrings":  {
                              "DefaultConnection":  "Server=localhost;Database=MiniCommerceAuthDb;Trusted_Connection=True;TrustServerCertificate=True"
                          },
    "Token":  {
                  "Audience":  "www.minicommerce.com",
                  "Issuer":  "www.minicommercee.com",
                  "AccessTokenExpirationMinutes":  15,
                  "RefreshTokenExpirationDays":  30,
                  "SecurityKey":  "CHANGE_ME_USE_USER_SECRETS_OR_ENVIRONMENT_VARIABLE"
              },
    "VerificationCode":  {
                             "ExpirationMinutes":  10,
                             "MaxAttempts":  5,
                             "Secret":  "CHANGE_ME_USE_USER_SECRETS_OR_ENVIRONMENT_VARIABLE"
                         },
    "AuthOutbox":  {
                       "BatchSize":  25,
                       "DispatcherIntervalSeconds":  10,
                       "CleanupIntervalMinutes":  15,
                       "LockSeconds":  60,
                       "RetryBaseDelaySeconds":  10,
                       "MaxRetryDelaySeconds":  300,
                       "ProcessedRetentionMinutes":  60,
                       "SensitiveRetentionMinutes":  30
                   },
    "Seq":  {
                "ServerURL":  "http://localhost:5341/"
            },
    "SensitiveEndpointRateLimit":  {
                                       "Policies":  {
                                                        "/api/Auth/login":  {
                                                                                "PermitLimit":  10,
                                                                                "WindowSeconds":  60
                                                                            },
                                                        "/api/Auth/emailChange":  {
                                                                                      "PermitLimit":  5,
                                                                                      "WindowSeconds":  900
                                                                                  },
                                                        "/api/User/register":  {
                                                                                   "PermitLimit":  5,
                                                                                   "WindowSeconds":  600
                                                                               },
                                                        "/api/Auth/forgotPassword":  {
                                                                                         "PermitLimit":  5,
                                                                                         "WindowSeconds":  900
                                                                                     },
                                                        "/api/Auth/mailVerify":  {
                                                                                     "PermitLimit":  5,
                                                                                     "WindowSeconds":  900
                                                                                 },
                                                        "/api/Auth/refreshTokenLogin":  {
                                                                                            "PermitLimit":  30,
                                                                                            "WindowSeconds":  60
                                                                                        },
                                                        "/api/User/updatePassword":  {
                                                                                         "PermitLimit":  10,
                                                                                         "WindowSeconds":  600
                                                                                     },
                                                        "/api/User/updateMailVerify":  {
                                                                                           "PermitLimit":  10,
                                                                                           "WindowSeconds":  600
                                                                                       },
                                                        "/api/User/updateUserEmail":  {
                                                                                          "PermitLimit":  10,
                                                                                          "WindowSeconds":  600
                                                                                      }
                                                    }
                                   }
}
